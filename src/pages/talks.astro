---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('talks')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const dateLong = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
});

const talkTypeLabel: Record<string, string> = {
  keynote: 'Keynote',
  talk: 'Talk',
  panel: 'Panel',
  tutorial: 'Tutorial',
  'pc-service': 'Service',
  webinar: 'Webinar',
};

const groupedByYear = new Map<number, typeof all>();
for (const t of all) {
  const y = t.data.date.getUTCFullYear();
  if (!groupedByYear.has(y)) groupedByYear.set(y, [] as any);
  groupedByYear.get(y)!.push(t as any);
}
const years = [...groupedByYear.keys()].sort((a, b) => b - a);
---

<Layout
  title="Talks — Srijan Saket"
  description="Keynotes, talks, workshop presentations, and program-committee service by Srijan Saket."
  pageType="inner"
>
  <section class="section lede">
    <h1>Speaking</h1>
    <p class="hero-sub">
      Keynotes, paper presentations, workshop talks, and conference service.
      Each entry links to a page with the slide deck embedded.
    </p>
  </section>

  {years.map((y) => (
    <section class="section year-group">
      <h2 class="year-label">{y}</h2>
      <ul class="talk-list">
        {groupedByYear.get(y)!.map((t) => (
          <li class="talk-item">
            <span class="talk-badge">{talkTypeLabel[t.data.type] ?? t.data.type}</span>
            <div class="talk-body">
              <h3 class="talk-title">
                <a href={`/talks/${t.id}/`}>{t.data.title}</a>
              </h3>
              <p class="talk-meta">
                {t.data.venue}{t.data.location ? ` · ${t.data.location}` : ''}
                <span class="sep">&middot;</span>
                {dateLong.format(t.data.date)}
              </p>
              {t.data.abstract && <p class="talk-abstract">{t.data.abstract}</p>}
              <p class="talk-micros">
                <a href={`/talks/${t.id}/`}>page &rarr;</a>
                {t.data.slides && <a href={t.data.slides} target="_blank" rel="noopener">slides &rarr;</a>}
                {t.data.video && <a href={t.data.video} target="_blank" rel="noopener">video &rarr;</a>}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Layout>

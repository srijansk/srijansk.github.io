---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTalks = await getCollection('talks');
const talks = allTalks
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

const allPubs = await getCollection('publications');
const papers = allPubs
  .filter((p) => p.data.type === 'paper')
  .sort((a, b) => b.data.year - a.data.year);
const patents = allPubs.filter((p) => p.data.type === 'patent');
const books = allPubs.filter((p) => p.data.type === 'book');

const allWriting = await getCollection('writing');
const writing = allWriting
  .filter((w) => w.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dateShort = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short' });
const talkTypeLabel: Record<string, string> = {
  keynote: 'Keynote',
  talk: 'Talk',
  panel: 'Panel',
  tutorial: 'Tutorial',
  'pc-service': 'Service',
  webinar: 'Webinar',
};
---

<Layout title="Srijan Saket — Tribal knowledge layer for LLM agents">
  <main id="top">
    <p class="skip-to">
      Skip to:
      <a href="#writing">writing</a><span>·</span>
      <a href="#publications">pubs</a><span>·</span>
      <a href="#talks">talks</a><span>·</span>
      <a href="#projects">projects</a><span>·</span>
      <a href="#contact">contact</a>
    </p>

    <section class="hero">
      <div class="hero-intro">
        <div class="hero-text">
          <h1>Srijan Saket</h1>
          <p class="hero-thesis">Building the tribal knowledge layer for LLM agents.</p>
        </div>
        <img
          class="hero-avatar"
          src="/srijan.png"
          alt="Portrait of Srijan Saket"
          width="96"
          height="96"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <p class="hero-sub">
        The context engine agents need to reason reliably over enterprise data — with principles
        that extend to personal-scale context too. Bringing the recommender-systems playbook to
        a problem the agent-memory world has not recognized as a recommendation problem.
      </p>
      <nav class="handles" aria-label="Social profiles">
        <a href="https://www.linkedin.com/in/srijansaket/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span>LinkedIn</span>
        </a>
        <a href="https://x.com/srijanskt2" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X</span>
        </a>
        <a href="https://github.com/srijansk" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          <span>GitHub</span>
        </a>
        <a href="https://scholar.google.com/citations?user=hheK6oIAAAAJ&hl=en" target="_blank" rel="noopener" aria-label="Google Scholar">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
          <span>Scholar</span>
        </a>
        <a href="mailto:srijanskt@gmail.com" aria-label="Email">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z"/><path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z"/></svg>
          <span>Email</span>
        </a>
      </nav>
      <p class="location">Seattle, WA</p>
    </section>

    <section id="now">
      <h2>Now</h2>
      <span class="now-date">April 2026</span>
      <p>
        Founding member at <strong>Pavo AI</strong> in Seattle, building the tribal knowledge
        layer for LLM agents. Currently focused on staged agentic composition,
        conflict-as-knowledge resolution, and bridging the recsys playbook to agent context.
        Writing essays on these themes; submitting research to 2026 conferences and workshops.
      </p>
    </section>

    <section id="career">
      <h2>Career</h2>
      <ul class="timeline">
        <li>
          <span class="dates">2025–</span>
          <span class="role">
            <strong>Pavo AI</strong>
            <span class="role-title"><span class="sep">·</span>Founding member</span>
            <span class="desc">Tribal knowledge layer for LLM agents.</span>
          </span>
        </li>
        <li>
          <span class="dates">2024–2025</span>
          <span class="role">
            <strong>Sourcegraph</strong>
            <span class="role-title"><span class="sep">·</span>IC-5 MLE</span>
            <span class="desc">LLM-driven code-search quality.</span>
          </span>
        </li>
        <li>
          <span class="dates">2017–2024</span>
          <span class="role">
            <strong>ShareChat</strong>
            <span class="role-title"><span class="sep">·</span>Staff MLE</span>
            <span class="desc">
              Scaled the recommender system from 1M to 200M users; led ML frameworks across
              content moderation, ranking, and feature pipelines.
            </span>
          </span>
        </li>
        <li>
          <span class="dates">2016–2017</span>
          <span class="role">
            <strong>Fidelity Investments</strong>
            <span class="role-title"><span class="sep">·</span>Data Scientist</span>
          </span>
        </li>
        <li>
          <span class="dates">2013–2015</span>
          <span class="role">
            <strong>IIT Kanpur</strong>
            <span class="role-title"><span class="sep">·</span>M.Tech, Mathematics &amp; Computing</span>
          </span>
        </li>
      </ul>
    </section>

    <section id="writing">
      <h2>Selected writing</h2>
      {writing.length === 0 ? (
        <p>First essays are in review — check back shortly.</p>
      ) : (
        <ul class="writing-list">
          {writing.map((w) => (
            <li>
              <span class="title">
                <a href={w.data.url} target="_blank" rel="noopener">{w.data.title}</a>
              </span>
              <span class="meta">{w.data.publication} · {dateShort.format(w.data.date)}</span>
              <span class="teaser">{w.data.teaser}</span>
            </li>
          ))}
        </ul>
      )}
      <p class="archive-line">
        Full archive:
        <a href="https://bitsnneurons.substack.com" target="_blank" rel="noopener">Bits &amp; Neurons →</a>
      </p>
    </section>

    <section id="publications">
      <h2>Publications</h2>
      <ul class="pubs">
        {papers.map((p) => (
          <li>
            <span class="pub-title">{p.data.title}.</span>
            <span class="pub-meta">
              {p.data.authors}{' · '}{p.data.venue}.
            </span>
            <span class="pub-links">
              {p.data.url && <a href={p.data.url} target="_blank" rel="noopener">[link]</a>}
              {p.data.arxiv && <a href={p.data.arxiv} target="_blank" rel="noopener">[arXiv]</a>}
              {p.data.pdf && <a href={p.data.pdf} target="_blank" rel="noopener">[PDF]</a>}
              {p.data.doi && <a href={`https://doi.org/${p.data.doi}`} target="_blank" rel="noopener">[DOI]</a>}
            </span>
          </li>
        ))}
      </ul>

      {patents.length > 0 && (
        <>
          <h3>Patents</h3>
          <ul class="pubs">
            {patents.map((p) => (
              <li>
                <span class="badge">Patent</span>
                <span class="pub-title">{p.data.title}.</span>
                <span class="pub-meta">{p.data.venue}.</span>
                {p.data.url && (
                  <span class="pub-links"><a href={p.data.url} target="_blank" rel="noopener">[link]</a></span>
                )}
              </li>
            ))}
          </ul>
        </>
      )}

      {books.length > 0 && (
        <>
          <h3>Book</h3>
          <ul class="pubs">
            {books.map((p) => (
              <li>
                <span class="badge">Book</span>
                <span class="pub-title">{p.data.title}.</span>
                <span class="pub-meta">{p.data.venue}.</span>
                {p.data.note && <span class="pub-meta">{p.data.note}</span>}
              </li>
            ))}
          </ul>
        </>
      )}

      <p class="archive-line">
        Full publication list:
        <a href="https://scholar.google.com/citations?user=hheK6oIAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar →</a>
      </p>
    </section>

    <section id="talks">
      <h2>Talks &amp; service</h2>
      <ul class="talk-list">
        {talks.map((t) => {
          const primary = t.data.slides || t.data.url || t.data.video;
          return (
            <li class="talk-item">
              <span class="talk-badge">{talkTypeLabel[t.data.type] ?? t.data.type}</span>
              <div class="talk-body">
                <span class="talk-title">
                  {primary ? (
                    <a href={primary} target="_blank" rel="noopener">{t.data.title}</a>
                  ) : (
                    t.data.title
                  )}
                </span>
                <span class="talk-meta">
                  {t.data.venue}{t.data.location ? ` · ${t.data.location}` : ''} · {dateShort.format(t.data.date)}
                </span>
                {(t.data.slides || t.data.video || t.data.url) && (
                  <span class="talk-micros">
                    {t.data.slides && <a href={t.data.slides} target="_blank" rel="noopener">slides →</a>}
                    {t.data.video && <a href={t.data.video} target="_blank" rel="noopener">video →</a>}
                    {t.data.url && !t.data.slides && <a href={t.data.url} target="_blank" rel="noopener">paper →</a>}
                  </span>
                )}
              </div>
            </li>
          );
        })}
      </ul>
      <p class="talks-all-link">
        <a href="/talks">Full talks list →</a>
      </p>
    </section>

    <section id="projects">
      <h2>Projects</h2>
      <ul class="projects">
        <li>
          <a class="project-name" href="https://github.com/srijansk/agent-relay" target="_blank" rel="noopener">agent-relay</a>
          <span class="flagship-badge">flagship</span>
          <span class="desc">
            Multi-agent workflow orchestrator, packaged as a docker-compose stack. Routes
            messages between specialist agents, persists state across long-running tasks,
            and keeps the execution surface small enough to debug in production.
          </span>
        </li>
        <li>
          <a class="project-name" href="https://github.com/srijansk/claude-ui" target="_blank" rel="noopener">claude-ui</a>
          <span class="desc">Web interface for Claude with document analysis and conversation history.</span>
        </li>
        <li>
          <a class="project-name" href="https://github.com/srijansk/LLMs-from-scratch" target="_blank" rel="noopener">LLMs-from-scratch</a>
          <span class="desc">Study fork — building GPT-style models in PyTorch, from the ground up.</span>
        </li>
      </ul>
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p class="contact-line">
        <a href="mailto:srijanskt@gmail.com">srijanskt@gmail.com</a>
      </p>
      <nav class="handles handles-contact" aria-label="Social profiles">
        <a href="https://www.linkedin.com/in/srijansaket/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span>LinkedIn</span>
        </a>
        <a href="https://x.com/srijanskt2" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X</span>
        </a>
        <a href="https://github.com/srijansk" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          <span>GitHub</span>
        </a>
        <a href="https://scholar.google.com/citations?user=hheK6oIAAAAJ&hl=en" target="_blank" rel="noopener" aria-label="Google Scholar">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
          <span>Scholar</span>
        </a>
      </nav>
    </section>

    <footer>
      Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> ·
      <a href="https://github.com/srijansk/srijansk.github.io" target="_blank" rel="noopener">source on GitHub →</a>
    </footer>
  </main>
</Layout>

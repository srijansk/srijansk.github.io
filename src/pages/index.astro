---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTalks = await getCollection('talks');
const talks = allTalks
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

const allPubs = await getCollection('publications');
const papers = allPubs
  .filter((p) => p.data.type === 'paper')
  .sort((a, b) => b.data.year - a.data.year);
const patents = allPubs.filter((p) => p.data.type === 'patent');
const books = allPubs.filter((p) => p.data.type === 'book');

const allWriting = await getCollection('writing');
const writing = allWriting
  .filter((w) => w.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dateShort = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short' });
const talkTypeLabel: Record<string, string> = {
  keynote: 'Keynote',
  talk: 'Talk',
  panel: 'Panel',
  tutorial: 'Tutorial',
  'pc-service': 'Service',
  webinar: 'Webinar',
};
---

<Layout title="Srijan Saket — Tribal knowledge layer for LLM agents" pageType="home">
  <section class="section lede">
    <h1 class="hero-thesis">Building the tribal knowledge layer for LLM agents.</h1>
    <p class="hero-sub">
      The context engine agents need to reason reliably over enterprise data — with principles
      that extend to personal-scale context too. Bringing the recommender-systems playbook
      to a problem the agent-memory world has not recognized as a recommendation problem.
    </p>
  </section>

  <section class="section" id="now">
    <span class="section-kicker">April 2026</span>
    <h2>What I'm working on</h2>
    <p>
      I'm a founding member at <strong>Pavo AI</strong> in Seattle, building the tribal
      knowledge layer for LLM agents. My day-to-day is a mix of staged agentic composition,
      conflict-as-knowledge resolution, and bridging the recommender-systems playbook to
      agent context. I'm writing essays on these themes and submitting research to 2026
      conferences and workshops.
    </p>
    <p>
      Before Pavo, seven years at <strong>ShareChat</strong> scaling the recommender system
      from 1M to 200M users, one year at <strong>Sourcegraph</strong> on LLM-driven
      code-search quality, and an undergrad &amp; master's at <strong>IIT Kanpur</strong> in
      Mathematics &amp; Computing.
    </p>
  </section>

  <section class="section" id="career">
    <h2>Career</h2>
    <ul class="timeline">
      <li>
        <span class="dates">2025 &mdash;</span>
        <span class="role">
          <strong>Pavo AI</strong><span class="sep">&middot;</span><span class="role-title">Founding member</span>
          <span class="desc">Tribal knowledge layer for LLM agents. Seattle, WA.</span>
        </span>
      </li>
      <li>
        <span class="dates">2024 &mdash; 2025</span>
        <span class="role">
          <strong>Sourcegraph</strong><span class="sep">&middot;</span><span class="role-title">IC-5 MLE</span>
          <span class="desc">LLM-driven code-search quality.</span>
        </span>
      </li>
      <li>
        <span class="dates">2017 &mdash; 2024</span>
        <span class="role">
          <strong>ShareChat</strong><span class="sep">&middot;</span><span class="role-title">Staff MLE</span>
          <span class="desc">Scaled the recommender system from 1M to 200M users; led ML frameworks across content moderation, ranking, and feature pipelines.</span>
        </span>
      </li>
      <li>
        <span class="dates">2016 &mdash; 2017</span>
        <span class="role">
          <strong>Fidelity Investments</strong><span class="sep">&middot;</span><span class="role-title">Data Scientist</span>
        </span>
      </li>
      <li>
        <span class="dates">2013 &mdash; 2015</span>
        <span class="role">
          <strong>IIT Kanpur</strong><span class="sep">&middot;</span><span class="role-title">M.Tech, Mathematics &amp; Computing</span>
        </span>
      </li>
    </ul>
  </section>

  <section class="section" id="writing">
    <h2>Selected writing</h2>
    <p class="section-lede">
      Essays and engineering war stories. I co-write the infra + AI newsletter
      <a href="https://bitsnneurons.substack.com" target="_blank" rel="noopener">Bits &amp; Neurons</a>
      with Vivek Chandela.
    </p>
    {writing.length === 0 ? (
      <p>First essays are in review &mdash; check back shortly.</p>
    ) : (
      <div class="writing-stack">
        {writing.map((w) => (
          <article class="writing-card">
            {w.data.thumbnail && (
              <a class="writing-thumb" href={w.data.url} target="_blank" rel="noopener" aria-label={`Open: ${w.data.title}`}>
                <img
                  src={w.data.thumbnail}
                  alt=""
                  width="480"
                  height="270"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="writing-body">
              <span class="writing-meta">
                {w.data.publication}
                <span class="sep">&middot;</span>
                {dateShort.format(w.data.date)}
              </span>
              <h3 class="writing-title">
                <a href={w.data.url} target="_blank" rel="noopener">{w.data.title}</a>
              </h3>
              <p class="writing-excerpt">{w.data.excerpt ?? w.data.teaser}</p>
              <p class="writing-cta">
                <a href={w.data.url} target="_blank" rel="noopener">Read on {w.data.publication} &rarr;</a>
              </p>
            </div>
          </article>
        ))}
      </div>
    )}
    <p class="archive-line">
      Full archive on
      <a href="https://bitsnneurons.substack.com" target="_blank" rel="noopener">Bits &amp; Neurons &rarr;</a>
    </p>
  </section>

  <section class="section" id="publications">
    <h2>Publications</h2>
    <p class="section-lede">
      Published at WWW, RecSys, SIGIR, and CIKM. Full list on
      <a href="https://scholar.google.com/citations?user=hheK6oIAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>.
    </p>
    <ul class="pubs">
      {papers.map((p) => (
        <li>
          <span class="pub-title">{p.data.title}.</span>
          <span class="pub-meta">
            {p.data.authors}<span class="sep">&middot;</span>{p.data.venue}.
          </span>
          <span class="pub-links">
            {p.data.url && <a href={p.data.url} target="_blank" rel="noopener">link</a>}
            {p.data.arxiv && <a href={p.data.arxiv} target="_blank" rel="noopener">arXiv</a>}
            {p.data.pdf && <a href={p.data.pdf} target="_blank" rel="noopener">PDF</a>}
            {p.data.doi && <a href={`https://doi.org/${p.data.doi}`} target="_blank" rel="noopener">DOI</a>}
          </span>
        </li>
      ))}
    </ul>

    {patents.length > 0 && (
      <>
        <h3>Patents</h3>
        <ul class="pubs">
          {patents.map((p) => (
            <li>
              <span class="pub-title"><span class="badge">Patent</span>{p.data.title}.</span>
              <span class="pub-meta">{p.data.venue}.</span>
              {p.data.url && (
                <span class="pub-links"><a href={p.data.url} target="_blank" rel="noopener">link</a></span>
              )}
            </li>
          ))}
        </ul>
      </>
    )}

    {books.length > 0 && (
      <>
        <h3>Book</h3>
        <ul class="pubs">
          {books.map((p) => (
            <li>
              <span class="pub-title"><span class="badge">Book</span>{p.data.title}.</span>
              <span class="pub-meta">{p.data.venue}.</span>
              {p.data.note && <span class="pub-note">{p.data.note}</span>}
            </li>
          ))}
        </ul>
      </>
    )}
  </section>

  <section class="section" id="talks">
    <h2>Speaking</h2>
    <p class="section-lede">
      Keynotes, paper presentations, and conference service. Each entry links to a page with
      the slide deck embedded.
    </p>
    <ul class="talk-list">
      {talks.map((t) => (
        <li class="talk-item">
          <span class="talk-badge">{talkTypeLabel[t.data.type] ?? t.data.type}</span>
          <div class="talk-body">
            <h3 class="talk-title">
              <a href={`/talks/${t.id}/`}>{t.data.title}</a>
            </h3>
            <p class="talk-meta">
              {t.data.venue}{t.data.location ? ` · ${t.data.location}` : ''}
              <span class="sep">&middot;</span>
              {dateShort.format(t.data.date)}
            </p>
            <p class="talk-micros">
              <a href={`/talks/${t.id}/`}>page &rarr;</a>
              {t.data.slides && <a href={t.data.slides} target="_blank" rel="noopener">slides &rarr;</a>}
              {t.data.video && <a href={t.data.video} target="_blank" rel="noopener">video &rarr;</a>}
            </p>
          </div>
        </li>
      ))}
    </ul>
    <p class="talks-all-link">
      <a href="/talks/">Full talks list &rarr;</a>
    </p>
  </section>

  <section class="section" id="projects">
    <h2>Projects</h2>
    <p class="section-lede">
      OSS experiments and study forks. Everything on
      <a href="https://github.com/srijansk" target="_blank" rel="noopener">GitHub</a>.
    </p>
    <ul class="projects">
      <li>
        <span class="project-header">
          <a class="project-name" href="https://github.com/srijansk/agent-relay" target="_blank" rel="noopener">agent-relay</a>
          <span class="flagship-badge">flagship</span>
        </span>
        <span class="desc">
          Multi-agent workflow orchestrator, packaged as a docker-compose stack. Routes
          messages between specialist agents, persists state across long-running tasks, and
          keeps the execution surface small enough to debug in production.
        </span>
      </li>
      <li>
        <span class="project-header">
          <a class="project-name" href="https://github.com/srijansk/claude-ui" target="_blank" rel="noopener">claude-ui</a>
        </span>
        <span class="desc">Web interface for Claude with document analysis and conversation history.</span>
      </li>
      <li>
        <span class="project-header">
          <a class="project-name" href="https://github.com/srijansk/LLMs-from-scratch" target="_blank" rel="noopener">LLMs-from-scratch</a>
        </span>
        <span class="desc">Study fork — building GPT-style models in PyTorch, from the ground up.</span>
      </li>
    </ul>
  </section>

  <section class="section" id="contact">
    <h2>Get in touch</h2>
    <p>
      The fastest route is <a href="mailto:srijanskt@gmail.com">srijanskt@gmail.com</a>. I
      read every DM on <a href="https://x.com/srijanskt2" target="_blank" rel="noopener">X</a>
      and <a href="https://www.linkedin.com/in/srijansaket/" target="_blank" rel="noopener">LinkedIn</a>,
      and I'm happy to talk about applied research, recsys-for-agents, and production ML.
    </p>
  </section>
</Layout>
